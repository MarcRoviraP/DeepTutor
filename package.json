{
  "name": "deeptutor",
  "version": "1.0.0",
  "description": "Unified DeepTutor - React + Express + PostgreSQL",
  "private": true,
  "scripts": {
    "install:all": "pnpm install",
    "build:client": "pnpm --filter client build",
    "server": "pnpm --filter server start",
    "server:dev": "pnpm --filter server dev",
    "client": "pnpm --filter client dev",
    "admin": "node admin/server.js",
    "dev": "concurrently -n \"SERVER,CLIENT\" -c \"magenta,cyan\" \"pnpm run server:dev\" \"pnpm run client\"",
    "dev:all": "concurrently -n \"SERVER,CLIENT,ADMIN\" -c \"magenta,cyan,yellow\" \"pnpm run server:dev\" \"pnpm run client\" \"pnpm run admin\"",
    "avatar": "xdg-open http://localhost:5002/avatar/avatar-3d-voz.html",
    "start": "pnpm run build:client && pnpm run server",
    "all": "pnpm run install:all && pnpm run build:client && pnpm run server && pnpm run admin"
  },
  "dependencies": {},
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
